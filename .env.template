# 환경 설정
# dev, staging, prod
STAGE=dev

# 데이터베이스 설정 (PostgreSQL)
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=myapp
DB_HOST=localhost
DB_PORT=5432

# API 서버 설정
API_HOST=localhost
API_PORT=8080
API_X_API_KEY=api-x-api-key

# Redis 설정
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT 및 암호화 키 설정
CURSOR_SECRET=your-cursor-encryption-key-32chars
API_SECRET_KEY=your-super-secret-jwt-key-here-32chars

# 외부 API KEY
IP_INFO_TOKEN=ipinfo-token-here

# 구글 이메일
SMTP_USERNAME=smtp-id-here
SMTP_PASSWORD=smtp-password-here

# 스웨거용 계정
SWAGGER_ID=your-swagger-id
SWAGGER_PASSWORD=your-swagger-password